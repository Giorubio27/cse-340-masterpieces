<%- include('partials/header') %>
    <main>
        <h1>
            <%= title %>
        </h1>

        <div class="table-container">
            <table class="user-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Email (Username)</th>
                        <th>Role</th>
                    </tr>
                </thead>
                <tbody>
                    <% users.forEach(user=> { %>
                        <tr>
                            <td>
                                <%= user.name %>
                            </td>
                            <td>
                                <%= user.email %>
                            </td>
                            <td class="role-badge <%= user.role_name.toLowerCase() %>">
                                <%= user.role_name %>
                            </td>
                            <td>
                                <a href="/assign-projects/<%= user.user_id %>">Manage Projects</a>
                            </td>
                        </tr>
                        <% }); %>
                </tbody>
            </table>
        </div>
    </main>
    <%- include('partials/footer') %>