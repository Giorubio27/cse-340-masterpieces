<%- include('partials/header') %>
    <main>
        <h1>
            <%= title %>
        </h1>
        <p>Select the projects this user is volunteering for:</p>

        <form action="/assign-projects/<%= userId %>" method="POST">
            <div class="checkbox-list">
                <% projects.forEach(project=> { %>
                    <div class="form-check">
                        <input type="checkbox" name="projectIds" value="<%= project.project_id %>"
                            id="proj<%= project.project_id %>" <% if (assignedProjects.some(ap=> ap.project_id ===
                        project.project_id)) { %> checked <% } %>
                            >
                            <label for="proj<%= project.project_id %>">
                                <%= project.title %>
                            </label>
                    </div>
                    <% }); %>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-primary">Save Assignments</button>
                <a href="/users" class="btn-secondary">Cancel</a>
            </div>
        </form>
    </main>
    <%- include('partials/footer') %>