<%- include partials/header.ejs %>
<main>
    <h1><%= title %></h1>

    <form action="/new-project" method="POST" class="project-form">

        <div class="form-group">
            <label for="title">Project Title:</label>
            <input type="text" id="title" name="title" maxlength="150" required placeholder="e.g., Beach Cleanup">
        </div>

        <div class="form-group">
            <label for="description">Description:</label>
            <textarea id="description" name="description" maxlength="500" required></textarea>
        </div>

        <div class="form-group">
            <label for="location">Location:</label>
            <input type="text" id="location" name="location" maxlength="250" required placeholder="City or Venue">
        </div>

        <div class="form-group">
            <label for="date">Date</label>
            <input type="date" id="date" name="date" required>
        </div>

        <div class="form-group">
            <label for="organizationId">Organization</label>
            <select id="organizationId" name="organizationId" required>

                <option value="" disabled selected>Select an Organization</option>

                <% if (organizations && organizations.length> 0) { %>
                    <% organizations.forEach(org=> { %>
                        <option value="<%= org.organization_id %>">
                            <%= org.name %>
                        </option>
                        <% }) %>
                            <% } else { %>
                                <option value="">No organizations available</option>
                                <% } %>

            </select>
        </div>

        <button type="submit" class="btn-submit">Create Project</button>
    </form>

    <p><a href="/">Return to Homepage</a></p>
</main>
<%- include partials/footer.ejs %>

