<%- include('partials/header') %>
    <main>
        <h1>
            <%= project.title %>
        </h1>
        <% if (user && user.role_name==='admin') { %>
            <a href="/edit-project/<%= project.project_id %>" class="btn-edit">Edit Project</a>
            <% } %>


                <div class="project-details">
                    <p><strong>Description:</strong>
                        <%= project.description %>
                    </p>
                    <p><strong>Date:</strong>
                        <%= project.date.toDateString() %>
                    </p>
                    <p><strong>Location:</strong>
                        <%= project.location %>
                    </p>

                    <p><strong>Partner Organization:</strong>
                        <a href="/organization/<%= project.organization_id %>">
                            <%= project.organization_name %>
                        </a>
                    </p>
                </div>
                <h3>Categories</h3>
                <div class="tags">
                    <% categories.forEach(category=> { %>
                        <a href="/category/<%= category.category_id %>" class="tag">
                            <%= category.category_name %>
                        </a>
                        <% }) %>
                </div>


                <hr>
                <% if (user && user.role_name==='admin') { %>
                    <a href="/assign-categories/<%= project.project_id %>">Edit Categories</a>
                    <% } %>

                        <p><a href="/projects">← Back to All Upcoming Projects</a></p>
    </main>
    <%- include('partials/footer') %>